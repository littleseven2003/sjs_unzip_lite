{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sjs-unzip-tool",
  "version": "0.1.0-pre",
  "identifier": "com.littleseven.sjs-unzip-tool",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "sjs-unzip-tool",
        "width": 800,
        "height": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/7zz"]
  }
}
