{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sjs-unzip-tool",
  "version": "0.1.0",
  "identifier": "com.littleseven.sjs-unzip-tool",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "sjs-unzip-tool",
        "width": 800,
        "height": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/32x32.png"
    ],
    "externalBin": ["binaries/7zz"]
  }
}
